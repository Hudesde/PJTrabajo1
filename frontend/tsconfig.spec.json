/* Configuración de TypeScript usada SÓLO al compilar los tests con Jest.
   (Antes apuntaba a Jasmine; ahora usamos Jest -> types: ["jest","node"]). */
{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./out-tsc/spec",
    "esModuleInterop": true,
    "types": [
      "jest",
      "node"
    ]
  },
  "files": [
    "setup-jest.ts"
  ],
  "include": [
    "src/**/*.spec.ts",
    "src/**/*.d.ts"
  ]
}
