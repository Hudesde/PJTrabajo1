# =============================================================================
#  Variables de entorno de ejemplo.
#  Copia este archivo a ".env" y ajusta los valores:
#      cp .env.example .env
#  El archivo .env NO debe subirse al repositorio (está en .gitignore).
# =============================================================================

# ---------- PostgreSQL ----------
POSTGRES_USER=todo
POSTGRES_PASSWORD=todo
POSTGRES_DB=todo_db

# ---------- Seguridad JWT (backend) ----------
# Debe tener al menos 32 caracteres. Cambia este valor en producción.
APP_JWT_SECRET=dev-secret-key-change-me-please-32bytes-minimum
# Tiempo de vida del token en milisegundos (86400000 = 24 horas).
APP_JWT_EXPIRATION_MS=86400000
