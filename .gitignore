# ---------- Variables de entorno / secretos ----------
# El .env de este proyecto sólo contiene valores de DESARROLLO (sin secretos
# reales), por eso SÍ se versiona para facilitar el arranque tras un clon.
# Si necesitas secretos reales, ponlos en un .env.local (ignorado).
.env.local
.env.*.local

# ---------- Backend (Maven / Java) ----------
backend/target/
*.class
*.jar
*.war
!.mvn/wrapper/maven-wrapper.jar

# ---------- Frontend (Angular / Node) ----------
frontend/node_modules/
frontend/dist/
frontend/.angular/
frontend/coverage/
npm-debug.log*

# ---------- IDE / editores ----------
.idea/
.vscode/
*.iml
.settings/
.project
.classpath

# ---------- Sistema operativo ----------
.DS_Store
Thumbs.db

# ---------- Logs / depuración ----------
*.log
backend/error_debug.txt
